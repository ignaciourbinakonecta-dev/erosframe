# App
APP_NAME=AI Video Platform
DEBUG=True

# Auth
JWT_SECRET=change-me-to-something-secure-in-production

# Database (SQLite for dev)
DATABASE_URL=sqlite+aiosqlite:///./ai_video_platform.db

# Redis
REDIS_URL=redis://localhost:6379/0

# vast.ai
VAST_API_KEY=your_vast_api_key_here

# Storage (S3) – leave empty for local dev storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Audio
ELEVENLABS_API_KEY=
XTTS_ENABLED=false

# LoRA URLs
LORA_WAN_REMIX_URL=https://huggingface.co/FX-FeiHou/wan2.2-Remix
LORA_COLLECTION_URL=https://huggingface.co/rahul7star/wan2.2Lora
